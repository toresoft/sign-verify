<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <springProperty name="appName" source="spring.application.name"/>
  <springProperty name="sentryDsn" source="sentry.dsn" defaultValue=""/>
  <springProperty name="sentryBreadcrumbLevel" source="sentry.breadcrumb-level" defaultValue="INFO"/>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
      <providers>
        <timestamp/>
        <version/>
        <logLevel/>
        <threadName/>
        <loggerName/>
        <message/>
        <mdc/>
        <stackTrace/>
        <pattern>
          <pattern>{"app":"${appName}"}</pattern>
        </pattern>
      </providers>
    </encoder>
  </appender>
  <appender name="SENTRY" class="io.sentry.logback.SentryAppender">
    <options>
      <dsn>${sentryDsn}</dsn>
    </options>
    <!-- Only ERROR+ log events create Sentry issues -->
    <minimumEventLevel>ERROR</minimumEventLevel>
    <!-- Log events at/above this level become Sentry breadcrumbs for context. Resolved via Spring
         (springProperty above) so both the SENTRY_BREADCRUMB_LEVEL env var and the
         sentry.breadcrumb-level Spring property work; defaults to INFO. Use WARN to reduce volume. -->
    <minimumBreadcrumbLevel>${sentryBreadcrumbLevel}</minimumBreadcrumbLevel>
  </appender>
  <root level="INFO">
    <appender-ref ref="STDOUT"/>
    <appender-ref ref="SENTRY"/>
  </root>
  <logger name="eu.europa.esig" level="WARN"/>
</configuration>

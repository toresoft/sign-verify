# Copy to .env and fill in before `docker compose -f docker-compose.prod.yml up -d`.
# NEVER commit the real .env (it is git-ignored).

# External PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://db.example.internal:5432/signverify
SPRING_DATASOURCE_USERNAME=signverify
SPRING_DATASOURCE_PASSWORD=change-me

# Secret encryption master key — base64-encoded 32 bytes (256-bit).
# Generate with:  openssl rand -base64 32
APP_SECRET_MASTER_KEY=

# OAuth2 / OIDC issuer (required when app.security.oauth.enabled=true, the default)
APP_SECURITY_OAUTH_ISSUER_URI=https://idp.example.com/realms/signverify

# Password for the EU Official Journal keystore bundled in the image
APP_OJ_KEYSTORE_PASSWORD=
